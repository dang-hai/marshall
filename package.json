{
  "name": "marshall",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "./scripts/setup.sh",
    "dev": "bun run --filter @marshall/desktop dev & bun run --filter @marshall/backend dev",
    "dev:backend": "bun run --filter @marshall/backend dev",
    "build": "bun run --filter @marshall/shared build && bun run --filter @marshall/desktop build",
    "build:backend": "bun run --filter @marshall/backend build",
    "dev:marketing": "bun run --filter @marshall/marketing dev",
    "build:marketing": "bun run --filter @marshall/marketing build",
    "test:marketing": "bun run --filter @marshall/marketing test",
    "test:database": "bun run --filter @marshall/database test",
    "test:backend": "bun run --filter @marshall/backend test",
    "test:auth": "bun run --filter @marshall/auth test",
    "start": "bun run --filter @marshall/desktop start",
    "start:backend": "bun run --filter @marshall/backend start",
    "db:url": "node scripts/neon-branch-utils.mjs",
    "typecheck": "tsc --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,md,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "10.0.1",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "typescript": "^5.4.0"
  }
}
