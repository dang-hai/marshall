# Neon Database
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/dbname?sslmode=require
NEON_PROJECT_ID=your-neon-project-id
NEON_DATABASE_NAME=marshall
NEON_ROLE_NAME=marshall_owner

# Auth
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173
BETTER_AUTH_ELECTRON_PROTOCOL=marshall
BETTER_AUTH_OAUTH_PROXY_PRODUCTION_URL=https://marshall.run
BETTER_AUTH_OAUTH_PROXY_CURRENT_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Backend
PORT=3000
BACKEND_URL=http://localhost:3000

# Transcription
DEEPGRAM_API_KEY=your-deepgram-api-key

# Notion (optional - can also connect via Marshall Settings)
NOTION_TOKEN=your-notion-integration-token
