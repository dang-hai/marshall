    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "composite": true
  },
  "references": [
    { "path": "./packages/shared" },
    { "path": "./packages/database" },
    { "path": "./packages/auth" },
    { "path": "./packages/api" },
    { "path": "./packages/transcription" },
    { "path": "./apps/desktop" },
    { "path": "./apps/marketing" }
  ]
}
