{
  "name": "@marshall/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "preview": "electron-vite preview",
    "package": "electron-builder"
  },
  "dependencies": {
    "@marshall/api": "workspace:*",
    "@marshall/auth": "workspace:*",
    "@marshall/database": "workspace:*",
    "@marshall/shared": "workspace:*",
    "@marshall/transcription": "workspace:*",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@tanstack/react-query": "^5.50.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "superjson": "^2.2.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.3.0",
    "class-variance-authority": "^0.7.0",
    "lucide-react": "^0.378.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-store": "11.0.2",
    "electron-vite": "^2.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.marshall.app",
    "productName": "Marshall",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "${env.APPLE_TEAM_ID}"
      },
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Marshall needs microphone access to transcribe your voice during meetings.",
        "NSScreenCaptureUsageDescription": "Marshall needs screen capture access to transcribe audio from meeting applications."
      }
    },
    "dmg": {
      "sign": false
    },
    "extraResources": [
      {
        "from": "../../packages/transcription/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
