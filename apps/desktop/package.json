{
  "name": "@marshall/desktop",
  "version": "0.0.15",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "preview": "electron-vite preview",
    "test": "bun test test",
    "package": "electron-builder"
  },
  "dependencies": {
    "@better-auth/electron": "^1.5.5",
    "@marshall/api": "workspace:*",
    "@marshall/auth": "workspace:*",
    "@marshall/database": "workspace:*",
    "@marshall/shared": "workspace:*",
    "@marshall/transcription": "workspace:*",
    "@tanstack/react-query": "^5.50.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "conf": "^13.0.0",
    "electron-updater": "^6.3.9",
    "fs-extra": "11.3.4",
    "lucide-react": "^0.378.0",
    "node-fetch": "2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "superjson": "^2.2.0",
    "tailwind-merge": "^2.3.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-store": "11.0.2",
    "electron-vite": "^2.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.marshall.app",
    "productName": "Marshall",
    "publish": {
      "provider": "github",
      "owner": "dang-hai",
      "repo": "marshall"
    },
    "protocols": [
      {
        "name": "Marshall Protocol",
        "schemes": [
          "marshall"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "${env.APPLE_TEAM_ID}"
      },
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Marshall needs microphone access to transcribe your voice during meetings.",
        "NSScreenCaptureUsageDescription": "Marshall needs screen capture access to transcribe audio from meeting applications."
      }
    },
    "dmg": {
      "sign": false,
      "artifactName": "${productName}-${arch}.${ext}"
    },
    "extraResources": [
      {
        "from": "../../packages/transcription/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources",
        "to": "tray",
        "filter": [
          "tray*.png"
        ]
      },
      {
        "from": "../notch-companion/.build/release/NotchCompanion",
        "to": "notch-companion/NotchCompanion"
      }
    ]
  }
}
