{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Marshall",
  "colors": {
    "primary": "#1a1a1a",
    "light": "#1a1a1a",
    "dark": "#fafafa"
  },
  "modeToggle": {
    "default": "light",
    "isHidden": true
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": ["index", "quickstart"]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Download",
      "href": "https://github.com/dang-hai/marshall/releases"
    }
  },
  "contextual": {
    "options": ["copy", "claude", "cursor", "vscode", "mcp"]
  },
  "feedback": {
    "thumbsRating": true
  },
  "seo": {
    "indexing": "navigable"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/dang-hai/marshall"
    }
  }
}
